{
  "expo": {
    "name": "Paint Mixer",
    "slug": "Pigment",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pigment",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.Pigment"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#faf2e5",
        "foregroundImage": "./assets/images/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.Pigment"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon-trans.png",
          "imageWidth": 300,
          "resizeMode": "contain",
          "backgroundColor": "#e4d2b6",
          "dark": {
            "backgroundColor": "#e4d2b6"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bee5c865-750d-4db9-aff7-5b48d38cb6e6"
      }
    }
  }
}
